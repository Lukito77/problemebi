# Copy this file to ".env" for local development. NEVER commit your real .env.
# In production (Render, Railway, etc.) set these in the dashboard,
# not in a committed file.

# Port the server listens on. Render injects its own PORT, so leave this
# unset or set to 3000 for local dev.
PORT=3000

# Long random string used to sign admin JWT cookies.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, a random one is created on each restart - which logs everyone out.
JWT_SECRET=replace-me-with-a-long-random-string

# Admin password for /admin.html. Pick something strong.
ADMIN_PASSWORD=change-this-password

# Cookie Secure flag:
#   true   = always Secure (use this on HTTPS deployments like Render)
#   false  = never Secure  (use this for local http://localhost dev)
#   unset  = auto-detect from the request (recommended in most cases)
# Leave unset for local dev; set to "true" on Render.
# COOKIE_SECURE=true

# Optional. Doesn't affect cookies anymore - kept for compatibility.
NODE_ENV=development
