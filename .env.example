# Copy this file to ".env" and edit the values. The .env file is read
# automatically when the server starts. NEVER commit your real .env.

# Port the server listens on
PORT=3000

# Long random string used to sign session cookies. Generate a fresh one, e.g.
# in Node: require('crypto').randomBytes(32).toString('hex')
SESSION_SECRET=replace-me-with-a-long-random-string

# Password for the /admin.html page. Pick something strong.
ADMIN_PASSWORD=change-this-password

# Set to "production" when deploying behind HTTPS. This enables Secure cookies.
NODE_ENV=development
